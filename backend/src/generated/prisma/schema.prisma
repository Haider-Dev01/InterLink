// backend/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────────
// ENUMS (Validés CdC + ERD)
// ─────────────────────────────────────────────────────────────

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum OfferStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  INTERVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ParseStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ImportedFrom {
  UPLOAD
  JSON
  GITHUB
}

// ─────────────────────────────────────────────────────────────
// MODELES (100% alignés avec ERD validé)
// ─────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  role               Role      @default(CANDIDATE)
  isVerified         Boolean   @default(false)
  isBanned           Boolean   @default(false)
  location           String?
  availabilityMonths Int?
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?

  profile          Profile?
  company          Company?
  refreshTokens    RefreshToken[]
  cvDocuments      CvDocument[]
  applications     Application[]  @relation("CandidateApplications")
  notifications    Notification[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  auditLogs        AuditLog[]
  jobOffers        JobOffer[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique
  companyId      String?
  schoolId       String?
  firstName      String
  lastName       String
  bio            String?
  linkedinUrl    String?
  githubUsername String?
  githubData     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  school  School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@map("profiles")
}

model Company {
  id             String    @id @default(uuid())
  userId         String    @unique
  name           String
  industry       String?
  siteWeb        String?
  isVerified     Boolean   @default(false)
  isRejected     Boolean   @default(false)
  rejectedReason String?
  validatedAt    DateTime?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profiles  Profile[]
  jobOffers JobOffer[]

  @@map("companies")
}

model School {
  id        String   @id @default(uuid())
  name      String   @unique
  country   String?
  createdAt DateTime @default(now())

  profiles Profile[]

  @@map("schools")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String?
  createdAt DateTime @default(now())

  extractedSkills ExtractedSkill[]
  offerSkills     OfferSkill[]

  @@map("skills")
}

model CvDocument {
  id                 String                      @id @default(uuid())
  userId             String
  fileUrl            String
  isActive           Boolean                     @default(true)
  embedding          Unsupported("vector(384)")?
  importedFrom       ImportedFrom                @default(UPLOAD)
  parseStatus        ParseStatus                 @default(PENDING)
  parsedText         String?
  extractedSkillsRaw Json?
  retryCount         Int                         @default(0)
  lastAttemptAt      DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractedSkills ExtractedSkill[]
  matchScores     MatchScore[]

  @@map("cv_documents")
}

model ExtractedSkill {
  id           String @id @default(uuid())
  cvDocumentId String
  skillId      String
  confidence   Float?

  cvDocument CvDocument @relation(fields: [cvDocumentId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([cvDocumentId, skillId])
  @@map("extracted_skills")
}

model JobOffer {
  id             String                      @id @default(uuid())
  companyId      String
  recruiterId    String
  title          String
  description    String
  location       String?
  durationMonths Int?
  remote         Boolean                     @default(false)
  offerStatus    OfferStatus                 @default(DRAFT)
  embedding      Unsupported("vector(384)")?
  viewCount      Int                         @default(0)
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  deletedAt      DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recruiter    User          @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  offerSkills  OfferSkill[]
  applications Application[]
  matchScores  MatchScore[]

  @@map("job_offers")
}

model OfferSkill {
  offerId    String
  skillId    String
  isRequired Boolean @default(true)

  offer JobOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  skill Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([offerId, skillId])
  @@map("offer_skills")
}

model MatchScore {
  id           String   @id @default(uuid())
  candidateId  String
  offerId      String
  cvDocumentId String
  scoreCosinus Float
  scoreFinal   Float
  breakdown    Json
  computedAt   DateTime @default(now())

  cvDocument CvDocument @relation(fields: [cvDocumentId], references: [id], onDelete: Cascade)
  offer      JobOffer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([candidateId, offerId])
  @@map("match_scores")
}

model Application {
  id                String            @id @default(uuid())
  candidateId       String
  offerId           String
  applicationStatus ApplicationStatus @default(PENDING)
  coverLetter       String?
  appliedAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  candidate User      @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  offer     JobOffer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([candidateId, offerId])
  @@map("applications")
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  receiverId    String
  applicationId String?
  content       String
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  sender      User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  payload   Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
